{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/quran/(.*)",
      "destination": "/api/quran/[...slug]?slug=$1"
    },
    {
      "source": "/api/content/(.*)",
      "destination": "/api/content/[...slug]?slug=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
